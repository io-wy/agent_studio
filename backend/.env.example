# App
APP_NAME="Agent Studio"
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agent_studio

# Redis
REDIS_URL=redis://localhost:6379/0

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-studio

# Kubernetes
K8S_CONFIG_PATH=~/.kube/config
K8S_NAMESPACE_PREFIX=agent-studio

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# lakeFS
LAKEFS_ENDPOINT=http://localhost:8000
LAKEFS_ACCESS_KEY=minioadmin
LAKEFS_SECRET_KEY=minioadmin

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["*"]
